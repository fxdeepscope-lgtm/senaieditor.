<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Senai | Aditya Andy's Portfolio</title>
    
    <!-- CSS Link -->
    <link rel="stylesheet" href="style.css">
    
    <!-- Fonts -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
</head>
<body>

    <!-- Navigation -->
    <nav>
        <div class="logo">SENAI<span>.</span></div>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#services">Services</a>
            <a href="#workflow">Workflow</a>
            <a href="#testimonials">Testimonials</a>
            <button class="btn-dash" onclick="openDashboardLogin()">Client Dashboard</button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div>
            <h1>Hello, I'm <span>Aditya Andy</span></h1>
            <p>Freelance Video Editor | Motion Graphics Designer | Thumbnail Artist</p>
            <p>Crafting visual stories that stop the scroll.</p>
            <a href="#services" class="cta-btn">View My Work</a>
        </div>
    </section>

    <!-- Services -->
    <section id="services">
        <h2 class="section-title"><span>My Expertise</span></h2>
        <div class="services-grid">
            <div class="service-card">
                <i class="fas fa-video"></i>
                <h3>Video Editing</h3>
                <p>Seamless cuts, story-driven pacing, sound design, and color grading.</p>
            </div>
            <div class="service-card">
                <i class="fas fa-film"></i>
                <h3>Motion Graphics</h3>
                <p>Dynamic animations, kinetic typography, logo reveals.</p>
            </div>
            <div class="service-card">
                <i class="fas fa-image"></i>
                <h3>Thumbnails</h3>
                <p>High CTR clickbait designs optimized for the algorithm.</p>
            </div>
        </div>
    </section>

    <!-- Workflow -->
    <section id="workflow" style="background-color: var(--bg-panel);">
        <h2 class="section-title"><span>My Workflow</span></h2>
        <div class="workflow-container">
            <div class="step">
                <div class="step-number">01</div>
                <h3>Brief & Import</h3>
                <p>We discuss the vision. I receive raw footage.</p>
            </div>
            <div class="step">
                <div class="step-number">02</div>
                <h3>Sync & Rough Cut</h3>
                <p>Assembling the story and sending the rough cut.</p>
            </div>
            <div class="step">
                <div class="step-number">03</div>
                <h3>Refine & Export</h3>
                <p>Final color grading, sound mix, and delivery.</p>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section id="testimonials">
        <h2 class="section-title"><span>Testimonials</span></h2>
        <div class="testimonial-grid">
            <div class="review-card">
                <div class="stars">★★★★★</div>
                <p>"Aditya is incredibly talented. The editing brought my video to life!"</p>
                <div class="client-name">- Rahul S., YouTuber</div>
            </div>
            <div class="review-card">
                <div class="stars">★★★★★</div>
                <p>"Delivered fast and the quality was top notch. Highly recommended."</p>
                <div class="client-name">- Tech Reviewer</div>
            </div>
        </div>
    </section>

    <!-- PRO DASHBOARD (Initially Hidden) -->
    <section id="dashboard-view" class="dashboard-panel">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <h2>Client Dashboard <span style="color:var(--primary); font-size:0.8rem;">(Private)</span></h2>
            <button onclick="logout()" style="padding:10px 20px; background:red; border:none; color:white; cursor:pointer; border-radius:5px;">Logout</button>
        </div>
        
        <div class="dash-stats">
            <div class="stat-card">
                <div class="stat-number">15</div>
                <div class="stat-label">Projects Completed</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">2</div>
                <div class="stat-label">In Progress</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">100%</div>
                <div class="stat-label">Satisfaction Rate</div>
            </div>
        </div>

        <h3>Current Projects</h3>
        <table class="project-table">
            <thead>
                <tr>
                    <th>Client Name</th>
                    <th>Project Type</th>
                    <th>Date Received</th>
                    <th>Status</th>
                </tr>
            </thead>
