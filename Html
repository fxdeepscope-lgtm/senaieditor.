                <tr>
                    <td>Rahul S.</td>
                    <td>YouTube Video Edit</td>
                    <td>Oct 24, 2023</td>
                    <td><span class="status-badge status-progress">Editing</span></td>
                </tr>
                <tr>
                    <td>Tech Brand</td>
                    <td>Motion Graphics</td>
                    <td>Oct 25, 2023</td>
                    <td><span class="status-badge status-pending">