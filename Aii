          placeholder="Enter Video Topic (e.g. 'Tech Reviews')" 
          className="w-full p-3 bg-gray-900 text-white rounded-lg border border-gray-600 mb-4 focus:border-yellow-400 outline-none"
          onChange={(e) => setTopic(e.target.value)}
        />
        <button 
          onClick={handleGenerate}
          disabled={loading}
          className="w-full py-3 bg-yellow-500 hover:bg-yellow-400 text-black font-bold rounded-lg transition"
        >
          {loading ? 'Thinking...' : 'Generate Hook'}
        </button>
        {result && (
          <div className="mt-6 p-4 bg-gray-900 border-l-4 border-yellow-400">
            <p className="text-lg text-gray-200 italic">"{result}"</p>
            <button className="mt-2 text-xs text-yellow-400 underline">Copy to Clipboard</button>
          </div>
        )}
      </div>
    );
  };

  const VideoUpscaler = () => {
